<script>
  /* ──────────────────────────────────────────
     REGION DATA
  ────────────────────────────────────────── */
  const regionData = {
    norte: {
      icon: '🌳',
      title: 'Norte: Produção e Conservação da Amazônia',
      atividades: ['Açaí', 'Cacau', 'Castanha-do-Pará'],
      desafios: ['Combater o desmatamento'],
      solucoes: ['Sistemas agroflorestais', 'Monitoramento por satélite', 'Recuperação de áreas degradadas'],
      mensagem: 'Produzir sem destruir é essencial para preservar a maior floresta tropical do planeta.'
    },
    nordeste: {
      icon: '☀️',
      title: 'Nordeste: Inovação no Semiárido',
      atividades: ['Fruticultura', 'Algodão', 'Cana-de-açúcar'],
      desafios: ['Escassez hídrica'],
      solucoes: ['Irrigação inteligente', 'Reuso de água', 'Energia solar'],
      mensagem: 'A tecnologia transforma desafios climáticos em oportunidades de crescimento sustentável.'
    },
    'centro-oeste': {
      icon: '🌾',
      title: 'Centro-Oeste: O Coração do Agronegócio Brasileiro',
      atividades: ['Soja', 'Milho', 'Pecuária'],
      desafios: ['Conservação do Cerrado'],
      solucoes: ['Agricultura de precisão', 'Integração Lavoura-Pecuária-Floresta', 'Monitoramento por drones'],
      mensagem: 'Produção em larga escala e responsabilidade ambiental podem caminhar juntas.'
    },
    sudeste: {
      icon: '🚜',
      title: 'Sudeste: Tecnologia e Produtividade',
      atividades: ['Café', 'Cana-de-açúcar', 'Hortaliças'],
      desafios: ['Uso eficiente dos recursos naturais'],
      solucoes: ['Sensores inteligentes', 'Irrigação automatizada', 'Bioenergia'],
      mensagem: 'A inovação tecnológica é uma das maiores aliadas da sustentabilidade.'
    },
    sul: {
      icon: '🌿',
      title: 'Sul: Tradição e Sustentabilidade',
      atividades: ['Trigo', 'Soja', 'Produção leiteira'],
      desafios: ['Preservação do solo'],
      solucoes: ['Plantio direto', 'Rotação de culturas', 'Conservação de nascentes'],
      mensagem: 'Boas práticas agrícolas garantem produtividade para as futuras gerações.'
    }
  };

  /* ──────────────────────────────────────────
     MAP INTERACTION
  ────────────────────────────────────────── */
  const panel = document.getElementById('info-panel');
  let activeRegion = null;

  function showRegion(regionKey) {
    const d = regionData[regionKey];
    if (!d) return;

    // Remove active from all
    document.querySelectorAll('.region').forEach(r => r.classList.remove('active'));
    // Set active on clicked
    const el = document.querySelector(`[data-region="${regionKey}"]`);
    if (el) el.classList.add('active');

    panel.className = 'info-panel';

    panel.innerHTML = `
      <div class="panel-icon">${d.icon}</div>
      <p class="panel-title">${d.title}</p>

      <div class="panel-section">
        <p class="panel-label">🌾 Principais Atividades</p>
        <div class="panel-tags">${d.atividades.map(a => `<span class="tag">${a}</span>`).join('')}</div>
      </div>

      <div class="panel-section">
        <p class="panel-label">⚠️ Desafio</p>
        <div class="panel-tags">${d.desafios.map(a => `<span class="tag desafio">${a}</span>`).join('')}</div>
      </div>

      <div class="panel-section">
        <p class="panel-label">✅ Soluções</p>
        <div class="panel-tags">${d.solucoes.map(a => `<span class="tag solucao">${a}</span>`).join('')}</div>
      </div>

      <div class="panel-msg">"${d.mensagem}"</div>
    `;

    requestAnimationFrame(() => panel.classList.add('visible'));
    activeRegion = regionKey;
  }

  document.querySelectorAll('.region').forEach(el => {
    el.addEventListener('click', () => showRegion(el.dataset.region));
    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        showRegion(el.dataset.region);
      }
    });
    // Hover preview
    el.addEventListener('mouseenter', () => {
      if (!el.classList.contains('active')) {
        el.style.cursor = 'pointer';
      }
    });
  });

  /* ──────────────────────────────────────────
     QUIZ
  ────────────────────────────────────────── */
  const questions = [
    {
      q: 'O que você prefere para economizar água em uma lavoura?',
      opts: ['Irrigação inteligente com sensores', 'Uso livre sem controle', 'Só chover quando der', 'Não sei ao certo'],
      scores: [3, 0, 1, 1]
    },
    {
      q: 'Qual tecnologia você usaria para monitorar uma área de plantio?',
      opts: ['Drones e satélites', 'Visitas periódicas a pé', 'Perguntar aos vizinhos', 'Não monitoraria'],
      scores: [3, 2, 1, 0]
    },
    {
      q: 'Como você protegeria uma área de floresta próxima à fazenda?',
      opts: ['Criaria uma reserva legal e agrofloresta', 'Deixaria como está', 'Convertiria para pastagem', 'Não me preocuparia'],
      scores: [3, 2, 0, 0]
    },
    {
      q: 'Que tipo de energia você usaria em uma propriedade rural?',
      opts: ['Solar e eólica', 'Gerador a diesel', 'Rede elétrica comum', 'Tanto faz'],
      scores: [3, 1, 2, 1]
    },
    {
      q: 'O que é mais importante no agronegócio moderno?',
      opts: ['Produzir mais preservando o meio ambiente', 'Produzir ao máximo sem limites', 'Manter a tradição sem inovar', 'Reduzir a produção'],
      scores: [3, 0, 1, 1]
    }
  ];

  const results = [
    { min: 0,  max: 5,  medal: '🥉', title: 'Aprendiz da Sustentabilidade', desc: 'Você está começando sua jornada verde! Com mais conhecimento sobre práticas sustentáveis, você pode se tornar um guardião do agronegócio responsável.' },
    { min: 6,  max: 10, medal: '🥈', title: 'Guardião Ambiental', desc: 'Muito bem! Você já compreende a importância de equilibrar produção e preservação. Continue aprendendo e inspire outros ao seu redor!' },
    { min: 11, max: 15, medal: '🥇', title: 'Embaixador do Agro Sustentável', desc: 'Parabéns! Você é um verdadeiro embaixador do agronegócio sustentável. Sua visão equilibrada entre inovação, produção e preservação é o futuro do Brasil!' }
  ];

  let currentQ = 0;
  let totalScore = 0;
  let answered = false;

  function renderQuiz() {
    const q = questions[currentQ];
    document.getElementById('quiz-question').textContent = `${currentQ + 1}. ${q.q}`;

    const opts = document.getElementById('quiz-options');
    opts.innerHTML = '';
    q.opts.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'quiz-opt';
      btn.textContent = opt;
      btn.setAttribute('aria-label', `Opção: ${opt}`);
      btn.addEventListener('click', () => selectAnswer(i, btn));
      opts.appendChild(btn);
    });

    // Progress
    const prog = document.getElementById('quiz-progress');
    prog.innerHTML = '';
    questions.forEach((_, i) => {
      const dot = document.createElement('div');
      dot.className = 'quiz-dot' + (i < currentQ ? ' done' : i === currentQ ? ' active' : '');
      prog.appendChild(dot);
    });

    answered = false;
  }

  function selectAnswer(idx, btn) {
    if (answered) return;
    answered = true;
    btn.classList.add('selected');

    totalScore += questions[currentQ].scores[idx];

    setTimeout(() => {
      currentQ++;
      if (currentQ < questions.length) {
        renderQuiz();
      } else {
        showResult();
      }
    }, 600);
  }

  function showResult() {
    document.getElementById('quiz-content').style.display = 'none';
    document.getElementById('quiz-progress').style.display = 'none';
    const res = document.getElementById('quiz-result');
    res.style.display = 'block';

    const r = results.find(r => totalScore >= r.min && totalScore <= r.max) || results[2];
    document.getElementById('result-medal').textContent = r.medal;
    document.getElementById('result-title').textContent = r.title;
    document.getElementById('result-desc').textContent = r.desc;
  }

  document.getElementById('btn-restart').addEventListener('click', () => {
    currentQ = 0;
    totalScore = 0;
    document.getElementById('quiz-content').style.display = 'block';
    document.getElementById('quiz-progress').style.display = 'flex';
    document.getElementById('quiz-result').style.display = 'none';
    renderQuiz();
  });

  renderQuiz();

  /* ──────────────────────────────────────────
     ACCESSIBILITY
  ────────────────────────────────────────── */
  const btnDark  = document.getElementById('btn-dark');
  const btnFontLg = document.getElementById('btn-font-lg');
  const btnFontXl = document.getElementById('btn-font-xl');
  const btnFontRst = document.getElementById('btn-font-rst');

  btnDark.addEventListener('click', () => {
    const on = document.body.classList.toggle('dark-mode');
    btnDark.setAttribute('aria-pressed', on);
    btnDark.classList.toggle('active', on);
    btnDark.textContent = on ? '☀️ Modo Claro' : '🌙 Modo Escuro';
  });

  function setFont(cls) {
    document.body.classList.remove('font-large', 'font-xlarge');
    if (cls) document.body.classList.add(cls);
    btnFontLg.classList.toggle('active', cls === 'font-large');
    btnFontXl.classList.toggle('active', cls === 'font-xlarge');
  }

  btnFontLg.addEventListener('click',  () => setFont('font-large'));
  btnFontXl.addEventListener('click',  () => setFont('font-xlarge'));
  btnFontRst.addEventListener('click', () => setFont(''));

  /* ──────────────────────────────────────────
     SCROLL REVEAL
  ────────────────────────────────────────── */
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('show'); });
  }, { threshold: 0.12 });
  revealEls.forEach(el => observer.observe(el));
</script>
